alias :q='exit'
alias backup='~/util/backup'
alias bc='bc -q '
alias br='sudo vi /sys/class/backlight/intel_backlight/brightness'
alias bs='source ~/.bashrc'
alias C='~/util/gcc'
alias cb='xsel -cb'
alias cdf='cd ~/.dotfiles'
alias cp='cp -i'
alias dd='dd status=progress '
alias delem='~/util/delempty'
#alias dpi='spoof-dpi -port 12345'
#alias ed='clear; ed -p: -v '
alias ed='clear; ed'
alias ex='nex'
alias f='. ~/util/falias'
alias feh='feh -Z '
alias ga.='git add .'
alias gaa='git add -A'
alias gb='git branch '
alias gbd='git branch -d '
alias gc='git commit '
alias gcA='git commit --amend'
alias gcm='git commit -m '
alias gC='git checkout '
alias gCb='git checkout -b '
alias gd='git diff '
alias gds='git diff --staged '
alias gl='git log '
alias gm='git merge '
alias gs='git status '
alias gss='git status -s '
alias gp='git push '
alias gP='git pull '
alias grep='grep --color=auto'
alias han='~/util/han'
alias hanoi='python3 ~/src/hanoi/hanoi.py'
alias info='info --vi-keys'
alias kbd='setxkbmap -option caps:escape; xset r rate 190 40'
alias la='ls -a'
alias ls='ls --color=auto'
alias ll='ls -hal'
alias mt='~/util/matching_test'
alias mon='xrandr --output HDMI-1-1 --auto --left-of eDP-1 --output HDMI-1-2 --auto --left-of eDP-1 --output HDMI-1-3 --auto --left-of eDP-1 --output HDMI-1-4 --auto --left-of eDP-1; feh --bg-scale ~/images/wallpaper/selected/01.jpg --bg-scale ~/images/wallpaper/selected/06.jpg '
alias monoff='xrandr --output HDMI-1-1 --off --output HDMI-1-2 --off --output HDMI-1-3 --off --output HDMI-1-4 --off; feh --bg-scale ~/images/wallpaper/selected/01.jpg'
alias mv='mv -i'
alias nf='clear; neofetch'
#alias nfs="neofetch --color_blocks off | sed -e 's/\x1B\[[0-9;\?]*[a-zA-Z]//g' -e 's/^\s+$//'"
alias note='~/util/note'
alias pg='pacman -Q | grep '
#alias PG='cd ~/images/wallpaper/programming/; feh; cd - 1> /dev/null'
#alias pi='sudo pacman -S'
alias pq='pacman -Q > ~/.dotfiles/package_list2.txt && nvim ~/.dotfiles/package_list2.txt'
alias pu='echo "PACKAGE UPGRADE" && sudo pacman -Syu; pacman -Q |
    cut -d " " -f 1 > ~/.dotfiles/package_list.txt'
alias raf='~/util/raffle'
alias rasp='tmux renamew "RASP"; sudo picocom -b 115200 /dev/ttyUSB0'
alias rassh='ssh nonocar@rasbian'
alias rb='echo "FUN FUN RE-BOOT!" && sudo reboot '
alias sicp='racket -I sicp'
alias sd='echo "SHUTDOWN" && sudo shutdown -h 0'
alias t='tmux '
alias ta='tmux new -A -s'
alias tk='tmux kill-ses -t'
alias tl='tmux ls'
alias top='top -E g '
alias type='type -a '
alias sudo='sudo -E -s '
alias v=nvim
alias vi=nvi
#alias vidir='EDITOR=nvim; vidir; EDITOR='
alias vc='nvim --clean'
alias x='startx -- -nocursor'
alias xc=startx

function rascp {
    scp $* nonocar@rasbian:/home/nonocar/transfer
}
