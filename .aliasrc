#/bin/bash

alias ..='cd ..'
alias :q='exit'
alias bc='bc -q '
alias bs='source ~/.bashrc'
alias C='~/bash/./gcc.sh'
alias cdf='cd ~/.dotfiles'
alias f='. ~/bash/falias.sh'
alias feh='feh -Z '
alias ga.='git add .'
alias gaa='git add -A'
alias gb='git branch '
alias gbd='git branch -d '
alias gc='git commit '
alias gca='git commit -a '
alias gcam='git commit -am '
alias gcA='git commit --amend'
alias gcm='git commit -m '
alias gC='git checkout '
alias gCb='git checkout -b '
alias gd='git diff '
alias gds='git diff --staged '
alias gl='git log '
alias gm='git merge '
alias gs='git status '
alias gss='git status -s '
alias gp='git push '
alias gP='git pull '
alias grep='grep --color=auto'
alias la='ls -a'
alias ls='ls --color=auto'
alias ll='ls -hal'
alias nf='clear; neofetch'
alias pi='sudo pacman -S'
alias pq='pacman -Q > ~/.dotfiles/package_list2.txt && vi ~/.dotfiles/package_list2.txt'
alias pu='echo "PACKAGE UPGRADE" && sudo pacman -Syu && pacman -Q |
    cut -d " " -f 1 > ~/.dotfiles/package_list.txt'
alias rb='echo "FUN FUN RE-BOOT!" && sudo reboot '
alias sicp='racket -I sicp'
alias sd='echo "SHUTDOWN" && sudo shutdown -h 0'
alias t='tmux '
alias ta='tmux new -A -s 0'
alias tk='tmux kill-ses -t 0'
alias tl='tmux ls'
alias type='type -a '
alias sudo='sudo -E -s '
alias vi=nvim
alias vic='nvim --clean'
alias VI='/bin/vi'


function mc {
    mkdir -p $1
    cd $1
}
