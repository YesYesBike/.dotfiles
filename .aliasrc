#/bin/bash

alias ..='cd ..'
alias :q='exit'
#alias ae='vi ~/.aliasrc'
alias bc='bc -q '
#alias be='tmux rename-window "BASHRC" && vi ~/.bashrc'
alias bs='source ~/.bashrc'
alias C='~/bash/./gcc.sh'
#alias c=??????
alias cdf='cd ~/.dotfiles'
alias f='. ~/bash/falias.sh'
alias feh='feh -Z '
alias ga.='git add .'
alias gaa='git add -A'
alias gb='git branch '
alias gc='git commit '
alias gca='git commit -a '
alias gcam='git commit -am '
alias gcA='git commit --amend'
alias gcm='git commit -m '
alias gC='git checkout '
alias gCb='git checkout -b '
alias gd='git diff '
alias gds='git diff --staged '
alias gl='git log '
alias gm='git merge '
alias gs='git status '
alias gss='git status -s '
alias gp='git push '
alias gP='git pull '
alias grep='grep --color=auto'
#alias he='pushd > /dev/null ~/.dotfiles_private/projects/homepage/;
#    tmux rename-window "Homepage"; vi html/homepage.html; popd > /dev/null'
#alias le='pushd > /dev/null ~/localhost; vi .; popd > /dev/null'
alias la='ls -a'
alias ls='ls --color=auto'
alias ll='ls -al'
#alias mt='. ~/bash/mantotxt.sh '  #I didn't know :Man when I wrote this...
alias pi='sudo pacman -S'
alias pq='pacman -Q > ~/.dotfiles/package_list2.txt && vi ~/.dotfiles/package_list2.txt'
alias pu='echo "PACKAGE UPGRADE" && sudo pacman -Syu && pacman -Q |
    cut -d " " -f 1 > ~/.dotfiles/package_list.txt'
alias rb='echo "FUN FUN RE-BOOT!" && sudo reboot '
alias sicp='racket -I sicp'
alias sd='echo "SHUTDOWN" && sudo shutdown -h 0'
alias t='tmux '
alias ta='tmux new -A -s 0'
#alias te='tmux rename-window ".tmux.conf" && vi ~/.tmux.conf'
#alias twe='vi ~/.tmux-windownames'
alias tk='tmux kill-ses -t 0'
alias tl='tmux ls'
alias type='type -a '
alias sudo='sudo -E -s '
alias vi=nvim
#alias ve='pushd > /dev/null ~/.config/nvim; tmux rename-window "NVIM_SET";
#    vi ~/.config/nvim/init.lua; popd > /dev/null'
#alias vf='. ~/bash/vimfile.sh'     use M-space instead


function mc {
    mkdir -p $1
    cd $1
}
