#/bin/bash

alias ..='cd ..'
alias :q='exit'
alias bc='bc -q '
alias bs='source ~/.bashrc'
alias C='~/util/gcc'
alias cdf='cd ~/.dotfiles'
alias cnote='~/util/clean_note'
alias ed='clear; ed -p: -v '
alias f='. ~/util/falias'
alias feh='feh -Z '
alias ga.='git add .'
alias gaa='git add -A'
alias gb='git branch '
alias gbd='git branch -d '
alias gc='git commit '
alias gca='git commit -a '
alias gcam='git commit -am '
alias gcA='git commit --amend'
alias gcm='git commit -m '
alias gC='git checkout '
alias gCb='git checkout -b '
alias gd='git diff '
alias gds='git diff --staged '
alias gl='git log '
alias gm='git merge '
alias gs='git status '
alias gss='git status -s '
alias gp='git push '
alias gP='git pull '
alias grep='grep --color=auto'
alias info='info --vi-keys '
alias la='ls -a'
alias ls='ls --color=auto'
alias ll='ls -hal'
alias mtest='~/util/matching_test'
alias nf='clear; neofetch'
alias note='~/util/quicknote'
alias pi='sudo pacman -S'
alias pq='pacman -Q > ~/.dotfiles/package_list2.txt && vi ~/.dotfiles/package_list2.txt'
alias pu='echo "PACKAGE UPGRADE" && sudo pacman -Syu && pacman -Q |
    cut -d " " -f 1 > ~/.dotfiles/package_list.txt'
alias raf='~/perl/raffle'
alias rb='echo "FUN FUN RE-BOOT!" && sudo reboot '
alias rnote='~/util/random_note2'
alias sicp='racket -I sicp'
alias sd='echo "SHUTDOWN" && sudo shutdown -h 0'
alias t='tmux '
alias ta='tmux new -A -s 1'
alias tk='tmux kill-ses -t 1'
alias tl='tmux ls'
alias top='top -E g '
alias type='type -a '
alias sudo='sudo -E -s '
alias v=nvim
alias vc='nvim --clean'
alias x='startx -- -nocursor'
alias xc=startx


function mc {
    mkdir -p $1
    cd $1
}
