#!/bin/perl
use utf8;
use strict;
use warnings;
use Data::Dumper;
use feature qw/
    say
/;
use Switch;

#알파벳 한글 변환기
#표준입출력을 한글로 변환하여 터미널 생활을 더욱 윤택하게
#theyt.net에서 소스코드를 참조하였으나
#코드를 이해하기 너무 어려워 아예 처음부터 만들었음.
#사용법: ./한 "알파벳 문자열"
#또는 전달인자 없이 쉘로 진입
#지금 읽고 있는 글도 이 프로그램의 도움으로 작성함



#exit 69 unless @ARGV;                       #Add schell later
binmode(STDOUT, ":encoding(UTF-8)");


my @한글배열 = split //, "ㄱㄲㄴㄷㄸㄹㅁㅂㅃㅅㅆㅇㅈㅉㅊㅋㅌㅍㅎㅏㅐㅑㅒㅓㅔㅕㅖㅗㅛㅜㅠㅡㅣ";

my %알파벳에서숫자로 = (
    r =>  0, R =>  1, s =>  2, e =>  3, E =>  4, f =>  5,
    a =>  6, q =>  7, Q =>  8, t =>  9, T => 10, d => 11,
    w => 12, W => 13, c => 14, z => 15, x => 16, v => 17,
    g => 18, k => 19, o => 20, i => 21, O => 22, j => 23,
    p => 24, u => 25, P => 26, h => 27, y => 28, n => 29,
    b => 30, m => 31, l => 32,
);

my %중성번호 = (
    ㅏ =>  0, ㅐ =>  1, ㅑ =>  2, ㅒ =>  3, ㅓ =>  4,
    ㅔ =>  5, ㅕ =>  6, ㅖ =>  7, ㅗ =>  8, ㅘ =>  9,
    ㅙ => 10, ㅚ => 11, ㅛ => 12, ㅜ => 13, ㅝ => 14,
    ㅞ => 15, ㅟ => 16, ㅠ => 17, ㅡ => 18, ㅢ => 19,
    ㅣ => 20,
);

my %종성번호 = (
    ㄱ =>  0, ㄲ =>  1, ㄳ =>  2, ㄴ =>  3, ㄵ =>  4,
    ㄶ =>  5, ㄷ =>  6, ㄹ =>  7, ㄺ =>  8, ㄻ =>  9,
    ㄼ => 10, ㄽ => 11, ㄾ => 12, ㄿ => 13, ㅀ => 14,
    ㅁ => 15, ㅂ => 16, ㅄ => 17, ㅅ => 18, ㅆ => 19,
    ㅇ => 20, ㅈ => 21, ㅊ => 22, ㅋ => 23, ㅌ => 24,
    ㅍ => 25, ㅎ => 26,
);

my %종성초성변환 = (
    0  => 0,  1  => 1,  3  => 2,  6  => 3,  7 => 5,
    15 => 6,  16 => 7,  18 => 9,  19 => 10, 20 => 11,
    21 => 12 ,22 => 14, 23 => 15, 24 => 16, 25 => 17,
    26 => 18 ,
);

my %번호중성 = reverse %중성번호;

my %쌍자음 = (   #종성,초성  종성
    "0,9"  => 2,   "3,12" => 4,  "3,18" => 5,
    "7,0"  => 8,   "7,6"  => 9,  "7,7"  => 10,
    "7,9"  => 11,  "7,16" => 12, "7,17" => 13,
    "7,18" => 14,  "16,9"  => 17,
);

my %쌍자음반대로 = reverse %쌍자음;

my %이중모음 = (   #중성,초성  중성
    "8,19"  => 9,  "8,20"  => 10, "8,32"  => 11,
    "13,23" => 14, "13,24" => 15, "13,32" => 16,
    "18,32" => 19,
);

my @출력값;
my $입력값 = join ' ', @ARGV;


my $초성;
my $중성;
my $종성;


sub 글자입력{
    my @전달인자 = @_;
    $_ //= -1 for (@전달인자);
    my $반환값 = 0xac00 + 21*28*$전달인자[0] + 28*$전달인자[1] + $전달인자[2] + 1;
    push @출력값, chr($반환값);
}

sub 자음{
    my ($글자, $서수) = @_;
    if(!defined $중성){
        if(!defined $종성){
            if(!defined $초성){
                $초성 = $서수;
            } else {
                push @출력값, $한글배열[$초성];
                $초성 = $서수;
            }
        }
    } else {
        if(!defined $종성){
            if(!defined $초성){
                push @출력값, $번호중성{$중성};
                undef $중성;
                $초성 = $서수;
            } else {
                $종성 = $종성번호{$글자};
            }
        } else {
            if(defined $초성){
                if( my $임시변수 = $쌍자음{"$종성,$서수"} ){
                    $종성 = $임시변수;
                } else {
                    글자입력($초성, $중성, $종성);
                    undef $중성;
                    undef $종성;
                    $초성 = $서수;
                }
            }
        }
    }
}

sub 모음{
    my ($글자, $서수) = @_;

    if(!defined $초성){
        if(defined $종성){
            if(my $임시변수 = $쌍자음반대로{$종성}){
                $임시변수 =~ /(\d)+,(\d)+/;
                $종성 = $1;
                글자입력($초성, $중성, $종성);
                $초성 = $2;
                undef $종성;
            }
        } else {
            push @출력값, $글자;
        }
    } else {
        if(!defined $종성){
            if(!defined $중성){
                $중성 = $중성번호{$글자};
            } else {
                if(my $임시변수 = $이중모음{"$중성,$서수"}){
                    $중성 = $임시변수;
                } else {
                    글자입력($초성, $중성, $종성);
                    undef $초성;
                    undef $중성;
                    push @출력값, $글자;
                }
            }
        } else {
            my $임시초성;
            my $임시종성;
            if(my $임시변수 = $쌍자음반대로{$종성}){
                $임시변수 =~ /(\d+),(\d+)/;
                $종성 = $1;
                $임시초성 = $2;
                글자입력($초성, $중성, $종성);
                undef $종성;
            } else {
                $임시종성 = $종성;
                undef $종성;
                글자입력($초성, $중성, $종성);
            }

            if(defined $임시초성){
                $초성 = $임시초성;
            } else {
                $초성 = $종성초성변환{$임시종성};
            }
            $중성 = $중성번호{$글자};
        }
    }
}

sub 한글화{
    my $입력값 = $_[0];

    for my $입력문자(split //, $입력값){
        my $서수 = $알파벳에서숫자로{$입력문자};
        my $글자 = $한글배열[$서수] if defined $서수;

        if(!defined $서수){
            글자입력($초성, $중성, $종성);
            undef $초성;
            undef $중성;
            undef $종성;
            push @출력값, $입력문자;
            next;
        }

        if($서수 < 19){
            자음($글자, $서수);
        } else {
            모음($글자, $서수);
        }
    }



    if(defined $초성){
        if(defined $중성){
            글자입력($초성, $중성, $종성);
        } else {
            push @출력값, $한글배열[$초성];
        }
    } else {
        if(defined $중성){
            push @출력값, $중성번호{$중성};
        } else {
            push @출력값, $종성번호{$종성} if(defined $종성);
        }
    }

    undef $초성;
    undef $중성;
    undef $종성;

    print join '', @출력값;
}

sub 도움말{
    #Function
}


if(@ARGV){                              #Starts Here
    한글화($입력값);
} else {
    say "알파벳-한글 변환기(:q 종료, :h 도움말)";
    print "> ";
    while(<STDIN>){
        chomp;
        switch($_){
            case ':q' { exit }
            case ':c' { system("clear"); print "> " }
            case ':h' { 도움말 }
            case '' { print "> " }
            else {
                한글화 $_;
                undef @출력값;
                print "\n> ";
            }
        }
    }
}
